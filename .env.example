# Server
PORT=3000
ADMIN_TOKEN=change-me-long-random-value

# Render paid persistent disk. Keep this path aligned with render.yaml.
SESSION_DIR=/var/data/session
DATA_DIR=/var/data/data

# WhatsApp behavior
BOT_NAME=David
OWNER_NAME=Your Name
AUTO_REPLY=true
REPLY_TRIGGER=question_or_mention
ONLY_GROUPS=true
ALLOW_ALL_CHATS=false
ALLOWED_CHAT_IDS=
BLOCKED_CHAT_IDS=
MAX_REPLY_CHARS=1200
MIN_SECONDS_BETWEEN_REPLIES=15

# Optional OpenAI reply generation. If empty, the bot uses local knowledge fallback.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Edit data/knowledge.md with your real platform/app answers.
KNOWLEDGE_PATH=data/knowledge.md
