# Dashboard access
ADMIN_TOKEN=change-me-long-random-value
NOTIFY_TOKEN=

# AI secrets. Add these in Render env, not in GitHub.
GROQ_API_KEY=
GROQ_API_KEYS=
OPENAI_API_KEY=

# Incident bridge and voice replies.
MEGAFIT_API_URL=
MEGAFIT_API_TOKEN=
DECAISSEMENT_CHAT_ID=
VOICE_REPLIES=true
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Optional local-only overrides. Render uses PORT and /var/data automatically.
PORT=3000

# Behavior, models, allowed chats, knowledge, and memory are managed at:
# /dashboard?token=ADMIN_TOKEN
